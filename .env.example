# Hotel Hunter — Environment Variables
# Copy this to .env and fill in your keys

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=your_key_here

# Optional: Google Places API key for real hotel data
# Without this, Google Hotels crawler uses stub data
# Get one at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=

# Optional: Control crawling behavior
MAX_HOTELS_PER_SOURCE=8       # How many hotels to analyze per source
MAX_IMAGES_PER_HOTEL=8        # Max images to send to vision (controls cost)
MAX_REVIEWS_PER_HOTEL=25      # Max reviews to send to text analysis
